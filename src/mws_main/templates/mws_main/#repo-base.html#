<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8"/>

    <title>{% block title %}{% endblock %}</title>
  </head>

  <body>
    <header>
      <a href="{% url 'mws_main:repo_home' tenant.repo_addr %}">{{ tenant.name }}</a>

      <nav>
	<ul>x
	  <li>
	    <form method="post" action="{% url 'mws_main:logout' tenant.repo_addr %}">
	      {% csrf_token %}
	      <input type="Submit" value="Log out">
	    </form>
	  </li>
	  <li>
	    <a href="{% url 'mws_main:view_profile' tenant.repo_addr %}">View profile</a>
	  </li>
	  {% block actions %}{% endblock %}
	</ul>
      </nav>
    </header>

    <main>
      {% block content %}{% endblock %}
    </main>

    <footer>
      <p>{{ tenant.name }}</p>
    </footer>

  </body>
</html>
